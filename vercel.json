{
  "version": 2,
  "outputDirectory": "apps/api/public",
  "buildCommand": "npx prisma generate --schema prisma/schema.prisma && echo \"Using prebuilt dist\"",
  "functions": {
    "api/index.js": {
      "includeFiles": "apps/api/{public,dist}/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
