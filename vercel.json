{
  "installCommand": "npm install --prefix apps/api",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "{apps/api/public/**,apps/api/node_modules/.prisma/client/**,prisma/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
